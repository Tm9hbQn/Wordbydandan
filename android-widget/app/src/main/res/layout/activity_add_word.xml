<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl">

    <!-- Tap outside to dismiss -->
    <View
        android:id="@+id/overlay_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialog_card_bg"
            android:padding="24dp"
            android:elevation="24dp"
            android:gravity="center_horizontal">

            <!-- Emoji header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨"
                android:textSize="40sp"
                android:layout_marginBottom="4dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dialog_title"
                android:textSize="24sp"
                android:textColor="@color/soft_purple"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <!-- Word input -->
            <EditText
                android:id="@+id/word_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/dialog_word_hint"
                android:textSize="22sp"
                android:textColor="@color/deep_purple"
                android:textColorHint="@color/hint"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:gravity="center"
                android:inputType="text"
                android:imeOptions="actionNext"
                android:maxLines="1"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <!-- Age label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dialog_age_label"
                android:textSize="14sp"
                android:textColor="@color/deep_purple"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Age buttons row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/age_buttons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center" />
            </HorizontalScrollView>

            <!-- Notes input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dialog_notes_label"
                android:textSize="14sp"
                android:textColor="@color/deep_purple"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/notes_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/dialog_notes_hint"
                android:textSize="14sp"
                android:textColor="@color/deep_purple"
                android:textColorHint="@color/hint"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:gravity="start|top"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="3"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <!-- Category label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dialog_category_label"
                android:textSize="14sp"
                android:textColor="@color/deep_purple"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Category buttons -->
            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/category_buttons_flex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone" />

            <!-- Fallback: simple horizontal scroll for categories -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/category_buttons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Submit button -->
            <TextView
                android:id="@+id/submit_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dialog_submit"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/btn_gradient"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Cancel -->
            <TextView
                android:id="@+id/cancel_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dialog_cancel"
                android:textSize="14sp"
                android:textColor="@color/soft_purple"
                android:padding="8dp"
                android:alpha="0.7" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
